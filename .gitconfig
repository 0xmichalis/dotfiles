[user]
	email = kargakis@protonmail.com
	name = Michalis Kargakis
	signingkey = 1B2F98E9CC581893

[core]
	editor = vi
	excludesfile = ~/.gitignore

[branch]
    sort = -committerdate
    autoSetupMerge = always
    autoSetupRebase = always

[tag]
    sort = version:refname

[init]
    defaultBranch = main

[diff]
	algorithm = histogram
	mnemonicPrefix = true
	renames = true

[pull]
    rebase = true

[rebase]
	gpgSign = true
	autoSquash = true
	autoStash = true
	updateRefs = true

[help]
    autocorrect = prompt

[merge]
	conflictstyle = diff3

[push]
	default = simple
	autoSetupRemote = true

[transfer]
	fsckobjects = true

[fetch]
	fsckobjects = true
	prune = true

[receive]
	fsckObjects = true

[alias]
	ac = !git add . && git commit -S -am
	acn = !git add . && git commit --no-verify -S -am
	cn = commit --no-verify -S -m
	l = log --pretty=format:"%C(yellow)%h\\ %C(reset)%s\\ %C(green)[%an]" --decorate --date=short
	f = fetch
	fo = fetch origin
	fu = fetch upstream
	b = branch
	c = checkout
	cb = checkout -b
	p = push
	po = push origin
	gc = gc --prune=all
	cln = clean -fd .
	fpr = "!sh -c \"git fetch $1 pull/$2/head; git checkout FETCH_HEAD\" -"
	r = rebase
	revinit = update-ref -d HEAD
	st = status -s

[commit]
	gpgSign = true
	verbose = true

[gpg]
	program = gpg

[color]
	ui = auto
